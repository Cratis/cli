<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <AssemblyName>Cratis.Cli</AssemblyName>
        <RootNamespace>Cratis.Cli</RootNamespace>
        <PackageId>Cratis.Cli</PackageId>
        <IsPackable>true</IsPackable>
        <PackAsTool>true</PackAsTool>
        <ToolCommandName>cratis</ToolCommandName>
        <TargetFramework>net10.0</TargetFramework>
        <RuntimeIdentifiers></RuntimeIdentifiers>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Cratis.Chronicle.Connections" />
        <PackageReference Include="Cratis.Chronicle.Contracts" />
        <PackageReference Include="Spectre.Console" />
        <PackageReference Include="Spectre.Console.Cli" />
        <PackageReference Include="Grpc.Net.Client" />
        <PackageReference Include="Microsoft.Extensions.AI" />
        <PackageReference Include="Microsoft.Extensions.AI.OpenAI" />
        <PackageReference Include="Anthropic" />
        <PackageReference Include="OllamaSharp" />
        <PackageReference Include="Azure.AI.OpenAI" />
    </ItemGroup>

    <ItemGroup>
        <!-- Cratis -->
        <Using Include="Cratis.Chronicle.Contracts" />
        <Using Include="Cratis.Chronicle.Contracts.Primitives" />
        <Using Include="Cratis.Chronicle.Connections" />
        <Using Include="Cratis.Chronicle.Contracts.EventSequences" />
        <Using Include="Cratis.Chronicle.Contracts.Events" />
        <Using Include="Cratis.Chronicle.Contracts.Observation" />
        <Using Include="Cratis.Chronicle.Contracts.Projections" />
        <Using Include="Cratis.Chronicle.Contracts.ReadModels" />
        <Using Include="Cratis.Chronicle.Contracts.Recommendations" />
        <Using Include="Cratis.Chronicle.Contracts.Security" />
        <Using Include="Cratis.Json" />
        <!-- Spectre -->
        <Using Include="Spectre.Console" />
        <Using Include="Spectre.Console.Cli" />
        <!-- System -->
        <Using Include="System.ComponentModel" />
        <Using Include="System.Text.Json" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="Cratis.Cli.Specs" />
    </ItemGroup>
</Project>
